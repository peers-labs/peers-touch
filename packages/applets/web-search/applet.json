{
  "manifestVersion": 2,
  "id": "web-search",
  "name": "Web Search",
  "version": "1.0.0",
  "description": "Web search and information retrieval",
  "author": "Peers Touch",
  "icon": "assets/icon.png",
  "main": "index.html",
  "load": {
    "type": "lynx",
    "entry": "index.html"
  },
  "bridge": {
    "version": 2,
    "protocol": "peers-touch.applet.bridge.v2"
  },
  "permissions": [
    "storage",
    "network",
    "notification"
  ],
  "minPlatformVersion": "0.1.0",
  "targetPlatforms": ["desktop", "mobile"]
}
